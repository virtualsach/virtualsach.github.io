---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import GridBackground from '../components/GridBackground.astro';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
	title: string;
    description?: string;
    image?: string;
}

const { 
    title, 
    description = "Virtual Sachin: Associate Director, Systems Thinker, and Builder of Resilient Clouds.", 
    image = "/social-card.png"
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, Astro.url)} />

		<title>{title}</title>
        <ViewTransitions />
	</head>
	<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col font-sans antialiased selection:bg-blue-500/30">
        <GridBackground />
        
		<!-- Navigation -->
		<header class="fixed w-full top-0 z-50 glass border-b border-white/5" transition:persist>
			<nav class="container mx-auto px-6 h-20 flex justify-between items-center">
				<a href="/" class="text-xl font-bold tracking-tight">
					Virtual<span class="text-blue-400">Sachin</span>.
				</a>
				
				<div class="hidden md:flex gap-8 items-center">
					<a href="/about" class="text-sm font-medium hover:text-blue-400 transition-colors">About</a>
					<a href="/projects" class="text-sm font-medium hover:text-blue-400 transition-colors">Projects</a>
					<a href="/blog" class="text-sm font-medium hover:text-blue-400 transition-colors">Insights</a>
					<a href="/contact" class="px-5 py-2 rounded-full border border-blue-500/30 text-blue-400 text-sm font-medium hover:bg-blue-500/10 transition-all">
						Let's Talk
					</a>
				</div>
			</nav>
		</header>

		<!-- Main Content -->
		<main class="flex-grow pt-24" transition:animate="fade">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="border-t border-white/5 py-12 mt-20 glass relative z-10">
			<div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="text-slate-500 text-sm">
					© {new Date().getFullYear()} Virtual Sachin. All rights reserved.
				</div>
				<div class="flex gap-6">
					<a href="https://github.com/virtualsach" target="_blank" class="text-slate-400 hover:text-white transition-colors">GitHub</a>
					<a href="https://www.linkedin.com/in/sachin-sharma-711/" target="_blank" class="text-slate-400 hover:text-white transition-colors">LinkedIn</a>
					<a href="https://twitter.com/virtualsachin" target="_blank" class="text-slate-400 hover:text-white transition-colors">Twitter</a>
				</div>
			</div>
		</footer>
        
        <CommandPalette />
	</body>
</html>
