---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Virtual Sachin">
	<main class="container mx-auto px-4 py-8">
		<h1 class="text-4xl font-bold mb-8 text-blue-400">Virtual Sachin</h1>
        <p class="mb-12 text-xl">Migration to Astro Successful.</p>
		
		<section>
			<h2 class="text-2xl font-bold mb-4">Latest Insights</h2>
			<ul class="space-y-4">
				{recentPosts.map((post) => (
					<li class="p-4 border border-slate-700 rounded-lg hover:bg-slate-800 transition">
						<a href={`/blog/${post.slug}`} class="block">
							<h3 class="text-xl font-semibold">{post.data.title}</h3>
							<p class="text-sm text-slate-400">{post.data.date.toLocaleDateString()}</p>
                            {post.data.description && <p class="mt-2 text-slate-300">{post.data.description}</p>}
						</a>
					</li>
				))}
			</ul>
		</section>
	</main>
</Layout>
