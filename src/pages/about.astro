---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('About page not found');

const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <main class="container mx-auto px-6 py-12 max-w-4xl">
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          {entry.data.description}
        </p>
      )}
    </header>

    <div class="glass-card p-8 md:p-12 prose prose-invert prose-lg mx-auto">
      <Content />
    </div>
  </main>
</Layout>
